# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_POOL_SIZE=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# AI Model Configuration (Mistral/OpenAI compatible)
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_API_BASE_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-large-latest

# WhatsApp Integration (Meta Graph API)
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
META_WHATSAPP_ACCESS_TOKEN=your_meta_access_token
META_WHATSAPP_PHONE_NUMBER_ID=your_meta_phone_id
META_WHATSAPP_WABA_ID=your_waba_id
META_WHATSAPP_VERIFY_TOKEN=your_verify_token
META_API_VERSION=v18.0

# Twilio Configuration (Fallback/Legacy)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token

# Gmail Integration (SMTP/IMAP)
SUPPORT_EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_POLL_INTERVAL=30

# Gmail OAuth (if using OAuth instead of App Password)
GMAIL_CLIENT_ID=your_client_id
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Application Configuration
ENVIRONMENT=production
LOG_LEVEL=INFO
PYTHONPATH=/app
PYTHONUNBUFFERED=1
PORT=8080

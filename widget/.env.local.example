# Copy to .env.local and fill in your values

# URL of your running Resolv backend (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Your brand UUID from the Resolv dashboard → Settings → Brand
NEXT_PUBLIC_BRAND_ID=your-brand-uuid-here

# Your org/tenant UUID (same as the JWT tenant_id in your account)
NEXT_PUBLIC_ORG_ID=your-org-uuid-here
